# Panel port on host
PANEL_PORT=8090

# Host path mounted into container for cloudflared config (config.yml)
CLOUDFLARED_CONFIG_DIR=/etc/cloudflared

# Base home directory for user browsing
HOME_BASE=/home

# Origin certificate for cloudflared CLI (tunnel route dns, etc.)
# Usually the cert.pem from `cloudflared tunnel login`
TUNNEL_ORIGIN_CERT=/home/msquad/.cloudflared/cert.pem
